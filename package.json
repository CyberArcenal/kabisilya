{
  "name": "kabisilya",
  "private": true,
  "version": "v1.0.0-beta.4",
  "main": "src/main/index.js",
  "author": {
    "name": "CyberArcenal",
    "email": "cyberarcenal1@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CyberArcenal/kabisilya.git"
  },
  "build": {
    "appId": "com.CyberArcenal.kabisilya.app",
    "productName": "Kabisilya",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": "dmg",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "CyberArcenal",
      "repo": "kabisilya",
      "releaseType": "release"
    }
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"electron ./src/main/index.js\"",
    "build": "vite build && electron-builder --publish never",
    "electron:dev": "electron ./src/main/index.js",
    "electron:build": "electron-builder",
    "migration:generate": "npx typeorm migration:generate src/migrations/InitSchema -d src/main/db/data-source.js --outputJs",
    "migration:run": "typeorm migration:run -d ./src/db/data-source.js",
    "migration:revert": "typeorm migration:revert -d ./src/db/data-source.js",
    "seed": "node src/seeders/seedData.js",
    "seed:reset": "node src/seeders/seedData.js --reset",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.563.0",
    "moment": "^2.30.1",
    "nodemailer": "^7.0.12",
    "p-queue": "^9.1.0",
    "pdfkit": "^0.17.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.13.0",
    "react-transition-group": "^4.4.5",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "twilio": "^5.11.1",
    "typeorm": "^0.3.28",
    "vite": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
